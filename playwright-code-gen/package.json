{
  "name": "playwright-codegen",
  "version": "1.0.0",
  "description": "Playwright tests with domain-driven structure",
  "main": "index.js",
  "scripts": {
    "test": "cucumber-js",
    "test:report": "cucumber-js && open-cli test-results/cucumber-report.html",
    "test:report:enhanced": "cucumber-js && node -e \"require('cucumber-html-reporter').generate({theme: 'bootstrap', jsonFile: 'test-results/cucumber-report.json', output: 'test-results/cucumber-report.html', reportSuiteAsScenarios: true, launchReport: true, screenshotsDirectory: 'test-results/screenshots/step-screenshots', storeScreenshots: true, screenshots: true});\"",
    "lint": "npx eslint .",
    "lint:fix": "npx eslint . --fix",
    "format": "npx prettier --write .",
    "format:check": "npx prettier --check ."
  },
  "keywords": [
    "playwright",
    "testing",
    "cucumber",
    "ddd"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@cucumber/cucumber": "^9.5.1",
    "@playwright/test": "^1.38.0",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.3",
    "open-cli": "^8.0.0",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  },
  "dependencies": {
    "axios": "^1.10.0",
    "dotenv": "^17.2.1"
  }
}
