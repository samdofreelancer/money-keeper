# Auto-detect text files and normalize to LF in the repo
* text=auto

# Force common text file types to use LF in the repository
*.ts     text eol=lf
*.js     text eol=lf
*.json   text eol=lf
*.md     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.html   text eol=lf
*.css    text eol=lf
*.scss   text eol=lf
*.sh     text eol=lf
*.gradle text eol=lf
*.xml    text eol=lf

# Treat images and other binary files as binary
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.pdf    binary

# Ensure executable scripts keep their executable bit on POSIX systems
*.sh     eol=lf

# End of file
